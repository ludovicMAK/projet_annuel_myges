{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@application/*": ["../../application/*"],
      "@domain/*": ["../../domain/*"],
      "@adapters/*": ["./*"]
    },
    "declaration": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "references": [{ "path": "../../domain" }, { "path": "../../application" }],
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
