{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@express/*": ["./*"],
      "@application/*": ["../../../application/*"],
      "@domain/*": ["../../../domain/*"]
    },
    "ignoreDeprecations": "5.0"
  },
  "references": [{ "path": "../../../domain" }, { "path": "../../../application" }],
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
