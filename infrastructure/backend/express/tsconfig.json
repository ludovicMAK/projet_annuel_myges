{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@express/*": ["./*"],
      "@adapters/*": ["../../adaptaters/*"],
      "@application/*": ["../../../application/*"],
      "@domain/*": ["../../../domain/*"]
    },
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "references": [{ "path": "../../../domain" }, { "path": "../../../application" }, { "path": "../../adaptaters" }],
  "include": ["src/**/*.ts", "types/**/*.ts", "db/**/*.ts", "controllers/**/*.ts", "schemas/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
