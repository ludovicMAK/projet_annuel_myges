{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@application/*": ["application/*"],
      "@domain/*": ["domain/*"],
      "@adapters/*": ["infrastructure/adaptaters/*"],
      "@express/*": ["infrastructure/backend/express/*"]
    }
  }
}